# ── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_VERSION=1.0.0

# ── Azure Application Insights ───────────────────────────────────────────────
# Get from Azure Portal → Application Insights → Connection String
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ── OpenAI (GPT-4) ───────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Anthropic (Claude) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-5

# ── Routing Thresholds ───────────────────────────────────────────────────────
# Complexity score [0-1] above which GPT-4 is preferred
COMPLEXITY_THRESHOLD=0.65
# Default latency budget in ms; requests under 1500ms always go to Claude
LATENCY_BUDGET_MS=3000
# Cost ratio ceiling before forcing cheaper model even for borderline complexity
MAX_TOKEN_COST_RATIO=1.5
# Fallback model if primary fails
FALLBACK_MODEL=claude
